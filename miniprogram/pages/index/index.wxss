/* 首页样式 */
page {
  background-color: #f5f7fa;
}

.container {
  padding: 30rpx;
}

/* 顶部栏 */
.top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.top-tip {
  background: #fff3e0;
  border-radius: 16rpx;
  padding: 16rpx 30rpx;
}

.tip-text {
  font-size: 26rpx;
  color: #e65100;
  font-weight: 500;
}

.history-link {
  font-size: 28rpx;
  color: #07c160;
  padding: 16rpx 20rpx;
}

.history-link:active {
  opacity: 0.7;
}

/* 区块通用 */
.section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.04);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
}

/* 岗位选择 */
.role-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.role-item {
  padding: 16rpx 40rpx;
  border-radius: 40rpx;
  background: #f0f0f0;
  font-size: 28rpx;
  color: #666;
  transition: all 0.2s;
}

.role-item.active {
  background: #07c160;
  color: #fff;
  font-weight: 500;
}

.role-item:active {
  opacity: 0.7;
}

/* 输入框 */
.question-input,
.bg-input {
  width: 100%;
  min-height: 140rpx;
  padding: 20rpx;
  box-sizing: border-box;
  border: 2rpx solid #e8e8e8;
  border-radius: 16rpx;
  font-size: 30rpx;
  color: #333;
  background: #fafafa;
}

.bg-input {
  min-height: 100rpx;
}

/* 快捷标签 */
.quick-tags {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  margin-top: 20rpx;
  gap: 16rpx;
}

.quick-label {
  font-size: 26rpx;
  color: #999;
}

.quick-item {
  padding: 8rpx 24rpx;
  background: #e8f5e9;
  color: #2e7d32;
  font-size: 26rpx;
  border-radius: 30rpx;
}

.quick-item:active {
  opacity: 0.7;
}

/* 底部操作 */
.action-area {
  margin-top: 40rpx;
  padding-bottom: 40rpx;
}

.generate-btn {
  width: 100%;
  height: 100rpx;
  background: #07c160;
  color: #fff;
  font-size: 34rpx;
  font-weight: bold;
  border-radius: 50rpx;
  text-align: center;
  border: none;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: normal;
}

.generate-btn::after {
  border: none;
}

.generate-btn.disabled {
  background: #a5d6a7;
}

.generate-btn:active {
  opacity: 0.85;
}

.sub-tip {
  text-align: center;
  font-size: 24rpx;
  color: #999;
  margin-top: 20rpx;
}

/* 次数预警（v1.3） */
.top-tip.warning {
  background: #ffebee;
}

.top-tip.warning .tip-text {
  color: #c62828;
}

.warning-banner {
  background: #fff3e0;
  border-radius: 16rpx;
  padding: 20rpx 30rpx;
  margin-bottom: 30rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.warning-icon {
  font-size: 32rpx;
}

.warning-text {
  font-size: 28rpx;
  color: #e65100;
  font-weight: 500;
}

/* 弹窗遮罩 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.6);
  z-index: 100;
}

/* 次数用尽弹窗（v1.3） */
.exhausted-modal {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 600rpx;
  max-width: 85vw;
  background: #fff;
  border-radius: 24rpx;
  z-index: 101;
  padding: 50rpx 40rpx;
  text-align: center;
}

.exhausted-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.exhausted-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.exhausted-desc {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 30rpx;
}

.exhausted-options {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.exhausted-option {
  display: flex;
  align-items: center;
  background: #f5f7fa;
  border-radius: 16rpx;
  padding: 24rpx 30rpx;
  text-align: left;
}

.exhausted-option:active {
  background: #e8e8e8;
}

.option-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.option-text {
  flex: 1;
}

.option-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 6rpx;
}

.option-sub {
  font-size: 26rpx;
  color: #999;
}

.exhausted-footer {
  font-size: 26rpx;
  color: #07c160;
  margin-bottom: 20rpx;
}

.exhausted-close {
  font-size: 28rpx;
  color: #999;
  padding: 16rpx;
}

.exhausted-close:active {
  opacity: 0.7;
}
