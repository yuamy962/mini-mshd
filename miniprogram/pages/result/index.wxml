<view class="container">
  <!-- 加载中 -->
  <block wx:if="{{loading}}">
    <view class="skeleton-box">
      <view class="skeleton-header">
        <view class="skeleton-title"></view>
        <view class="skeleton-subtitle"></view>
      </view>
      <view class="skeleton-card">
        <view class="skeleton-line short"></view>
        <view class="skeleton-line"></view>
        <view class="skeleton-line"></view>
      </view>
      <view class="skeleton-card">
        <view class="skeleton-line short"></view>
        <view class="skeleton-line"></view>
        <view class="skeleton-line"></view>
      </view>
      <view class="skeleton-card">
        <view class="skeleton-line short"></view>
        <view class="skeleton-line"></view>
      </view>
      <view class="loading-text">AI 正在生成回答，请稍候...</view>
    </view>
  </block>

  <!-- 错误提示 -->
  <block wx:elif="{{errorMsg}}">
    <view class="card" style="text-align:center; padding: 80rpx 30rpx;">
      <view style="font-size:32rpx; color:#666; margin-bottom:30rpx;">{{errorMsg}}</view>
      <button class="btn-primary" bindtap="onRegenerate">返回首页</button>
    </view>
  </block>

  <!-- 结果展示 -->
  <block wx:else>
    <!-- 头部 -->
    <view class="header">
      <view class="header-title">🔥 HR会点头的回答</view>
      <view class="header-subtitle">建议直接背诵，面试时用得上</view>
    </view>

    <!-- 一句话点评（v1.3 新增） -->
    <view class="card card-comment" wx:if="{{result.summaryComment}}">
      <view class="card-title">
        <text class="icon">💬</text>
        <text>一句话点评</text>
      </view>
      <view class="comment-content">{{result.summaryComment}}</view>
    </view>

    <!-- 评分模块 -->
    <view class="card card-score" wx:if="{{result.score && result.score.total}}">
      <view class="card-title">
        <text class="icon">📊</text>
        <text>你的回答评分</text>
      </view>
      <view class="score-main">
        <view class="score-circle">
          <text class="score-num">{{result.score.total}}</text>
          <text class="score-label">分</text>
        </view>
        <view class="score-detail">
          <view class="score-item">
            <text class="score-item-label">表达清晰度</text>
            <view class="score-bar-bg">
              <view class="score-bar-fill" style="width: {{result.score.clarity}}%;"></view>
            </view>
            <text class="score-item-val">{{result.score.clarity}}</text>
          </view>
          <view class="score-item">
            <text class="score-item-label">逻辑结构</text>
            <view class="score-bar-bg">
              <view class="score-bar-fill" style="width: {{result.score.logic}}%;"></view>
            </view>
            <text class="score-item-val">{{result.score.logic}}</text>
          </view>
          <view class="score-item">
            <text class="score-item-label">真实感</text>
            <view class="score-bar-bg">
              <view class="score-bar-fill" style="width: {{result.score.authenticity}}%;"></view>
            </view>
            <text class="score-item-val">{{result.score.authenticity}}</text>
          </view>
        </view>
      </view>
      <view class="score-suggestion" wx:if="{{result.score.suggestion}}">
        💡 {{result.score.suggestion}}
      </view>
      <view class="score-target" wx:if="{{result.improvedScore || result.score.target}}">
        <text class="target-text">当前评分：{{result.score.total}}分</text>
        <text class="target-arrow">→</text>
        <text class="target-text highlight">优化后：{{result.improvedScore || result.score.target}}分（更有说服力）</text>
      </view>
      <!-- v1.3 新增：优化到90+按钮 -->
      <view class="optimize-area" wx:if="{{!advancedResult && !showAdvancedLoading}}">
        <button class="btn-optimize" bindtap="onOptimizeTo90">✨ 优化到90+版本</button>
      </view>
      <view class="optimize-loading" wx:if="{{showAdvancedLoading}}">
        <text>AI 正在生成高分版本，请稍候...</text>
      </view>
    </view>

    <!-- 标准回答 -->
    <view class="card card-answer">
      <view class="card-title">
        <text class="icon">📝</text>
        <text>面试回答（标准版）</text>
      </view>
      <view class="card-content">{{result.answer}}</view>
      <view class="copy-btn" data-text="{{result.answer}}" bindtap="onCopyText">
        复制回答
      </view>
    </view>

    <!-- 面试官视角 -->
    <view class="card card-insight" wx:if="{{result.insight}}">
      <view class="card-title">
        <text class="icon">🧠</text>
        <text>面试官在想什么</text>
      </view>
      <view class="card-content">{{result.insight}}</view>
    </view>

    <!-- 面试雷点提醒（v1.3 新增） -->
    <view class="card card-risk" wx:if="{{result.riskTip}}">
      <view class="card-title">
        <text class="icon">⚠️</text>
        <text>面试雷点提醒</text>
      </view>
      <view class="risk-content">{{result.riskTip}}</view>
    </view>

    <!-- 高级表达（v1.2 增加锁定） -->
    <view class="card card-advanced" wx:if="{{result.advanced}}">
      <view class="card-title">
        <text class="icon">✨</text>
        <text>更高级的表达方式</text>
      </view>
      <view class="card-content {{!unlockedAdvanced ? 'content-locked' : ''}}">
        {{result.advanced}}
      </view>
      <!-- 锁定遮罩 -->
      <view class="lock-overlay" wx:if="{{!unlockedAdvanced}}">
        <view class="lock-mask"></view>
        <view class="lock-btn" data-type="advanced" bindtap="onShowUnlockModal">
          <text class="lock-icon">🔒</text>
          <text>查看完整版</text>
        </view>
      </view>
      <view class="copy-btn" wx:if="{{unlockedAdvanced}}" data-text="{{result.advanced}}" bindtap="onCopyText">
        复制高级表达
      </view>
    </view>

    <!-- 追问（v1.2 增加锁定） -->
    <view class="card card-followup" wx:if="{{result.followup}}">
      <view class="card-title">
        <text class="icon">👉</text>
        <text>可能追问 & 应对</text>
      </view>
      <view class="card-content {{!unlockedFollowup ? 'content-locked' : ''}}">
        {{result.followup}}
      </view>
      <!-- 锁定遮罩 -->
      <view class="lock-overlay" wx:if="{{!unlockedFollowup}}">
        <view class="lock-mask"></view>
        <view class="lock-btn" data-type="followup" bindtap="onShowUnlockModal">
          <text class="lock-icon">🔒</text>
          <text>查看完整版</text>
        </view>
      </view>
    </view>

    <!-- 推荐问题 -->
    <view class="card card-recommend" wx:if="{{result.recommendQuestions && result.recommendQuestions.length > 0}}">
      <view class="card-title">
        <text class="icon">💬</text>
        <text>你可能还会被问</text>
      </view>
      <view class="recommend-list">
        <view
          class="recommend-item"
          wx:for="{{result.recommendQuestions}}"
          wx:key="*this"
          data-text="{{item}}"
          bindtap="onRecommendQuestion"
        >
          {{item}}
        </view>
      </view>
    </view>

    <!-- 90+ 高分优化结果（v1.3 新增） -->
    <view class="card card-advanced-result" wx:if="{{advancedResult}}">
      <view class="card-title">
        <text class="icon">🏆</text>
        <text>90+ 高分优化版本</text>
      </view>
      <view class="advanced-section">
        <view class="advanced-label">高分回答</view>
        <view class="card-content">{{advancedResult.highScoreAnswer}}</view>
      </view>
      <view class="advanced-section" wx:if="{{advancedResult.optimizationNote}}">
        <view class="advanced-label">优化点说明</view>
        <view class="card-content">{{advancedResult.optimizationNote}}</view>
      </view>
      <view class="advanced-section" wx:if="{{advancedResult.enhancedInsight}}">
        <view class="advanced-label">面试官视角强化</view>
        <view class="card-content">{{advancedResult.enhancedInsight}}</view>
      </view>
      <view class="advanced-section" wx:if="{{advancedResult.deepFollowup}}">
        <view class="advanced-label">潜在追问（更深一层）</view>
        <view class="card-content">{{advancedResult.deepFollowup}}</view>
      </view>
    </view>

    <!-- 底部操作 -->
    <view class="bottom-action">
      <button class="btn-share" bindtap="onShowShareModal">📸 生成分享卡片</button>
      <button class="btn-primary" bindtap="onRegenerate">{{result.recommendQuestions && result.recommendQuestions.length > 0 ? '换个问题再试一次' : '再刷一个更好的回答'}}</button>
      <button class="btn-secondary" open-type="share">分享给朋友</button>
    </view>
  </block>
</view>

<!-- ===== 分享卡片弹窗（v1.2） ===== -->
<view class="modal-mask" wx:if="{{showShareModal}}" bindtap="onCloseShareModal"></view>
<view class="share-modal" wx:if="{{showShareModal}}">
  <view class="modal-header">
    <text class="modal-title">生成分享卡片</text>
    <view style="display:flex;align-items:center;gap:20rpx;">
      <text class="mode-toggle" bindtap="onToggleShareMode">{{shareMode === 'normal' ? '切换对比模式' : '切换普通模式'}}</text>
      <text class="modal-close" bindtap="onCloseShareModal">✕</text>
    </view>
  </view>
  <view class="modal-body">
    <!-- 绘制时显示 canvas，生成图片后隐藏 -->
    <view
      class="canvas-wrap"
      style="width: {{750 * canvasScale}}px; height: {{1100 * canvasScale}}px;"
      hidden="{{shareImagePath}}"
    >
      <canvas
        canvas-id="shareCanvas"
        style="width: 750px; height: 1100px; transform: scale({{canvasScale}}); transform-origin: top left;"
      />
    </view>
    <!-- 图片生成后显示图片，隐藏 canvas -->
    <image
      wx:if="{{shareImagePath}}"
      src="{{shareImagePath}}"
      mode="widthFix"
      style="width: {{750 * canvasScale}}px; display: block; margin: 0 auto; border-radius: 16rpx; box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.15);"
    />
  </view>
  <view class="modal-footer">
    <button class="btn-save" bindtap="onSaveShareImage" disabled="{{!shareImagePath}}">
      {{shareImagePath ? '保存到相册' : '生成中...'}}
    </button>
  </view>
</view>

<!-- ===== 分享引导弹窗（v1.3 P1） ===== -->
<view class="modal-mask" wx:if="{{showShareGuide}}" bindtap="onCloseShareGuide"></view>
<view class="share-guide-modal" wx:if="{{showShareGuide}}">
  <view class="guide-icon">🎉</view>
  <view class="guide-title">你的回答已超过80%求职者</view>
  <view class="guide-desc">分享出去，看看别人怎么评价？</view>
  <button class="btn-guide-share" bindtap="onShareNow">立即分享</button>
  <view class="guide-close" bindtap="onCloseShareGuide">稍后再说</view>
</view>

<!-- ===== 解锁弹窗（v1.2） ===== -->
<view class="modal-mask" wx:if="{{showUnlockModal}}" bindtap="onCloseUnlockModal"></view>
<view class="unlock-modal" wx:if="{{showUnlockModal}}">
  <view class="unlock-icon">🔓</view>
  <view class="unlock-title">解锁完整版</view>
  <view class="unlock-desc">
    开通即可查看高级表达和追问应对的完整内容
  </view>
  <view class="unlock-benefits">
    <view class="benefit-item">✅ 高级表达完整版</view>
    <view class="benefit-item">✅ 追问应对完整版</view>
    <view class="benefit-item">✅ 无限次生成</view>
  </view>
  <button class="btn-unlock-ad" bindtap="onUnlockByAd">
    🎬 观看广告免费解锁
  </button>
  <button class="btn-unlock-vip" bindtap="onUnlockFree">
    🎁 免费体验（测试）
  </button>
  <view class="unlock-close" bindtap="onCloseUnlockModal">稍后再说</view>
</view>
