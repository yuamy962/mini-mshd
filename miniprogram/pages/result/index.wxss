/* 结果页样式 */
page {
  background-color: #f5f7fa;
  padding-bottom: 60rpx;
}

.container {
  padding: 30rpx;
}

/* 头部 */
.header {
  text-align: center;
  margin-bottom: 40rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.header-subtitle {
  font-size: 26rpx;
  color: #999;
  margin-top: 10rpx;
}

/* 卡片通用 */
.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
  position: relative;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
}

.card-title .icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.card-content {
  font-size: 30rpx;
  color: #444;
  line-height: 1.8;
}

/* 评分卡片 */
.card-score {
  border-left: 8rpx solid #ff9500;
}

.score-main {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.score-circle {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: #fff3e0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-right: 30rpx;
  flex-shrink: 0;
}

.score-num {
  font-size: 48rpx;
  font-weight: bold;
  color: #e65100;
  line-height: 1;
}

.score-label {
  font-size: 24rpx;
  color: #e65100;
}

.score-detail {
  flex: 1;
}

.score-item {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.score-item:last-child {
  margin-bottom: 0;
}

.score-item-label {
  width: 140rpx;
  font-size: 26rpx;
  color: #666;
  flex-shrink: 0;
}

.score-bar-bg {
  flex: 1;
  height: 16rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  overflow: hidden;
  margin: 0 16rpx;
}

.score-bar-fill {
  height: 100%;
  background: #07c160;
  border-radius: 8rpx;
}

.score-item-val {
  width: 50rpx;
  font-size: 26rpx;
  color: #333;
  text-align: right;
  flex-shrink: 0;
}

.score-suggestion {
  font-size: 26rpx;
  color: #666;
  background: #f5f7fa;
  padding: 20rpx;
  border-radius: 12rpx;
  line-height: 1.6;
}

/* 标准回答卡片 */
.card-answer {
  border-left: 8rpx solid #07c160;
}

/* 面试官视角 */
.card-insight {
  border-left: 8rpx solid #ff9500;
}

/* 高级表达 */
.card-advanced {
  border-left: 8rpx solid #5856d6;
}

/* 追问 */
.card-followup {
  border-left: 8rpx solid #ff2d55;
}

/* 推荐问题 */
.card-recommend {
  border-left: 8rpx solid #2196f3;
}

.recommend-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.recommend-item {
  padding: 12rpx 28rpx;
  background: #e3f2fd;
  color: #1976d2;
  font-size: 28rpx;
  border-radius: 30rpx;
}

.recommend-item:active {
  opacity: 0.7;
}

/* 复制按钮 */
.copy-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: #07c160;
  color: #fff;
  font-size: 26rpx;
  padding: 12rpx 30rpx;
  border-radius: 30rpx;
  margin-top: 20rpx;
}

.copy-btn:active {
  opacity: 0.8;
}

/* 内容锁定（v1.2） */
.content-locked {
  max-height: 120rpx;
  overflow: hidden;
}

.lock-overlay {
  position: absolute;
  bottom: 30rpx;
  left: 30rpx;
  right: 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.lock-mask {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 200rpx;
  background: linear-gradient(to bottom, rgba(255,255,255,0), rgba(255,255,255,0.95));
  z-index: 1;
}

.lock-btn {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  background: #fff;
  border: 2rpx solid #07c160;
  color: #07c160;
  font-size: 28rpx;
  padding: 16rpx 40rpx;
  border-radius: 40rpx;
  margin-top: 80rpx;
  box-shadow: 0 4rpx 16rpx rgba(7,193,96,0.15);
}

.lock-btn:active {
  opacity: 0.8;
}

.lock-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
}

/* 底部操作 */
.bottom-action {
  margin-top: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.btn-primary {
  width: 80%;
  background: #07c160;
  color: #fff;
  font-size: 32rpx;
  border-radius: 50rpx;
}

.btn-primary::after {
  border: none;
}

.btn-primary:active {
  opacity: 0.85;
}

.btn-secondary {
  width: 80%;
  background: #fff;
  color: #666;
  font-size: 30rpx;
  border-radius: 50rpx;
  border: 2rpx solid #ddd;
}

.btn-secondary::after {
  border: none;
}

.btn-share {
  width: 80%;
  background: #ff9500;
  color: #fff;
  font-size: 32rpx;
  border-radius: 50rpx;
  margin-bottom: 10rpx;
}

.btn-share::after {
  border: none;
}

.btn-share:active {
  opacity: 0.85;
}

/* 加载状态 */
.loading-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.loading-text {
  margin-top: 30rpx;
  font-size: 28rpx;
  color: #999;
}

/* ===== 弹窗通用（v1.2） ===== */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.6);
  z-index: 100;
}

/* ===== 分享卡片弹窗（v1.2 全屏滚动模式） ===== */
.share-modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  background: #fff;
  z-index: 101;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  border-bottom: 2rpx solid #f0f0f0;
  flex-shrink: 0;
  background: #fff;
}

.modal-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  font-size: 36rpx;
  color: #999;
  padding: 10rpx;
}

.modal-body {
  flex: 1;
  padding: 20rpx;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  display: flex;
  justify-content: center;
  align-items: flex-start;
  background: #f5f5f5;
}

.canvas-wrap {
  overflow: hidden;
  flex-shrink: 0;
}

.modal-footer {
  padding: 20rpx 40rpx 40rpx;
  border-top: 2rpx solid #f0f0f0;
  flex-shrink: 0;
  background: #fff;
}

.btn-save {
  width: 100%;
  height: 90rpx;
  line-height: 90rpx;
  background: #07c160;
  color: #fff;
  font-size: 32rpx;
  border-radius: 45rpx;
  text-align: center;
  border: none;
}

.btn-save::after {
  border: none;
}

.btn-save[disabled] {
  background: #a5d6a7;
}

/* ===== 解锁弹窗（v1.2） ===== */
.unlock-modal {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 600rpx;
  max-width: 85vw;
  background: #fff;
  border-radius: 24rpx;
  z-index: 101;
  padding: 50rpx 40rpx;
  text-align: center;
}

.unlock-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.unlock-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.unlock-desc {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 30rpx;
  line-height: 1.6;
}

.unlock-benefits {
  background: #f5f7fa;
  border-radius: 16rpx;
  padding: 24rpx 30rpx;
  margin-bottom: 30rpx;
  text-align: left;
}

.benefit-item {
  font-size: 28rpx;
  color: #444;
  margin-bottom: 12rpx;
}

.benefit-item:last-child {
  margin-bottom: 0;
}

.btn-unlock-ad {
  width: 100%;
  height: 90rpx;
  line-height: 90rpx;
  background: #ff9500;
  color: #fff;
  font-size: 30rpx;
  border-radius: 45rpx;
  margin-bottom: 20rpx;
  text-align: center;
  border: none;
}

.btn-unlock-ad::after {
  border: none;
}

.btn-unlock-ad:active {
  opacity: 0.85;
}

.btn-unlock-vip {
  width: 100%;
  height: 90rpx;
  line-height: 90rpx;
  background: #fff;
  color: #07c160;
  font-size: 30rpx;
  border-radius: 45rpx;
  border: 2rpx solid #07c160;
  margin-bottom: 20rpx;
  text-align: center;
}

.btn-unlock-vip::after {
  border: none;
}

.btn-unlock-vip:active {
  opacity: 0.85;
}

.unlock-close {
  font-size: 28rpx;
  color: #999;
  padding: 16rpx;
}

.unlock-close:active {
  opacity: 0.7;
}
