/* 结果页样式 */
page {
  background-color: #f5f7fa;
  padding-bottom: 60rpx;
}

.container {
  padding: 30rpx;
}

/* 头部 */
.header {
  text-align: center;
  margin-bottom: 40rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.header-subtitle {
  font-size: 26rpx;
  color: #999;
  margin-top: 10rpx;
}

/* 卡片通用 */
.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
}

.card-title .icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.card-content {
  font-size: 30rpx;
  color: #444;
  line-height: 1.8;
}

/* 标准回答卡片 */
.card-answer {
  border-left: 8rpx solid #07c160;
}

/* 面试官视角 */
.card-insight {
  border-left: 8rpx solid #ff9500;
}

/* 高级表达 */
.card-advanced {
  border-left: 8rpx solid #5856d6;
}

/* 追问 */
.card-followup {
  border-left: 8rpx solid #ff2d55;
}

/* 复制按钮 */
.copy-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: #07c160;
  color: #fff;
  font-size: 26rpx;
  padding: 12rpx 30rpx;
  border-radius: 30rpx;
  margin-top: 20rpx;
}

.copy-btn:active {
  opacity: 0.8;
}

/* 重新生成按钮 */
.bottom-action {
  margin-top: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.btn-primary {
  width: 80%;
  background: #07c160;
  color: #fff;
  font-size: 32rpx;
  border-radius: 50rpx;
  margin-bottom: 20rpx;
}

.btn-primary::after {
  border: none;
}

.btn-primary:active {
  opacity: 0.85;
}

.btn-secondary {
  width: 80%;
  background: #fff;
  color: #666;
  font-size: 30rpx;
  border-radius: 50rpx;
  border: 2rpx solid #ddd;
}

.btn-secondary::after {
  border: none;
}

/* 加载状态 */
.loading-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.loading-text {
  margin-top: 30rpx;
  font-size: 28rpx;
  color: #999;
}
